# Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_CREDENTIALS_PATH=path/to/service-account-key.json
ALERT_EMAIL=your-email@example.com

# BigQuery Configuration
BIGQUERY_PROJECT_ID=your-bigquery-project-id
BIGQUERY_CREDENTIALS=base64-encoded-service-account-key

# Google Cloud Storage
GCS_CREDENTIALS=base64-encoded-service-account-key
GCS_BUCKET_NAME=your-gcs-bucket-name

# Kaggle API
KAGGLE_CREDENTIALS_PATH=path/to/kaggle.json
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Azure Storage (if applicable)
AZURE_STORAGE_CONNECTION_STRING=your-azure-connection-string
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name

# Database Configuration (if applicable)
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=your_database_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_secure_password

# API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Pub/Sub Configuration
PUBSUB_TOPIC_NAME=realtime-events
PUBSUB_SUBSCRIPTION_NAME=realtime-events-sub
PUBSUB_PROJECT_ID=your-gcp-project-id

# Pub/Sub Topics (for different projects)
REALTIME_EVENTS_TOPIC=realtime-events
QUALITY_ALERTS_TOPIC=data-quality-alerts
AUTOMATION_EVENTS_TOPIC=automation-events
JARVIS_COMMANDS_TOPIC=jarvis-commands
PIPELINE_NOTIFICATIONS_TOPIC=pipeline-notifications

# Pub/Sub Subscriptions
REALTIME_EVENTS_SUB=realtime-events-sub
QUALITY_ALERTS_SUB=quality-alerts-sub
AUTOMATION_EVENTS_SUB=automation-processor-sub
JARVIS_COMMANDS_SUB=jarvis-handler-sub
PIPELINE_NOTIFICATIONS_SUB=pipeline-notifications-sub

# Security Settings
JWT_SECRET=your-jwt-secret-key
ENCRYPTION_KEY=your-encryption-key
KMS_KEY_NAME=projects/your-project-id/locations/global/keyRings/your-keyring/cryptoKeys/your-key

{
  "displayName": "Real-time Streaming Pipeline",
  "gridLayout": {
    "columns": "2",
    "widgets": [
      {
        "title": "Message Processing Rate",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "prometheusQuerySource": {
                  "prometheusQuery": "rate(pubsub_message_published[5m])"
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Messages/sec"
            }
          ],
          "timeshiftDuration": "0s",
          "yAxis": {
            "scale": "LINEAR",
            "label": "Messages/sec"
          }
        }
      },
      {
        "title": "Pub/Sub Backlog",
        "scorecard": {
          "gaugeView": {
            "upperBound": 10000,
            "lowerBound": 0
          },
          "dataSets": [
            {
              "timeSeriesQuery": {
                "prometheusQuerySource": {
                  "prometheusQuery": "pubsub_subscription_num_undelivered_messages"
                }
              }
            }
          ]
        }
      },
      {
        "title": "Processing Latency",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "prometheusQuerySource": {
                  "prometheusQuery": "histogram_quantile(0.95, rate(processing_latency_seconds_bucket[5m]))"
                }
              },
              "plotType": "LINE",
              "legendTemplate": "95th percentile"
            }
          ],
          "yAxis": {
            "scale": "LINEAR",
            "label": "Latency (seconds)"
          }
        }
      },
      {
        "title": "Error Rate",
        "scorecard": {
          "gaugeView": {
            "upperBound": 10,
            "lowerBound": 0
          },
          "dataSets": [
            {
              "timeSeriesQuery": {
                "prometheusQuerySource": {
                  "prometheusQuery": "rate(processing_errors_total[5m]) * 100"
                }
              }
            }
          ]
        }
      }
    ]
  }
}

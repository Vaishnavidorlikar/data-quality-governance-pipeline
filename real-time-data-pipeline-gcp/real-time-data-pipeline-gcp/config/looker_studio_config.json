{
  "name": "Real-time Analytics Dashboard",
  "description": "Live real-time streaming pipeline metrics and analytics",
  "dataSources": [
    {
      "name": "Real-time Events",
      "type": "bigquery",
      "project_id": "${GCP_PROJECT_ID}",
      "dataset": "realtime_events",
      "table": "processed_data",
      "refresh": "30s"
    },
    {
      "name": "PubSub Metrics",
      "type": "bigquery",
      "project_id": "${GCP_PROJECT_ID}",
      "dataset": "streaming_metrics",
      "table": "pubsub_performance",
      "refresh": "15s"
    },
    {
      "name": "Monitoring API",
      "type": "web_connector",
      "url": "https://monitoring.googleapis.com/v3/projects/${GCP_PROJECT_ID}/timeSeries",
      "headers": {
        "Authorization": "Bearer ${ACCESS_TOKEN}"
      },
      "refresh": "10s"
    }
  ],
  "charts": [
    {
      "id": "live_message_rate",
      "title": "Live Message Rate",
      "type": "real_time_line",
      "dataSource": "PubSub Metrics",
      "dimensions": ["timestamp"],
      "metrics": ["messages_per_second"],
      "refreshInterval": 10
    },
    {
      "id": "processing_latency",
      "title": "Processing Latency",
      "type": "time_series",
      "dataSource": "Real-time Events",
      "dimensions": ["timestamp"],
      "metrics": ["avg_latency_ms"],
      "aggregation": "avg"
    },
    {
      "id": "error_rate",
      "title": "Error Rate",
      "type": "gauge",
      "dataSource": "Real-time Events",
      "metrics": ["error_percentage"],
      "ranges": [{"min": 0, "max": 10}]
    },
    {
      "id": "system_health",
      "title": "System Health",
      "type": "status_indicators",
      "dataSource": "Monitoring API",
      "metrics": ["pubsub_health", "processing_health", "storage_health"]
    }
  ],
  "filters": [
    {
      "id": "time_window",
      "type": "select",
      "options": ["Last 5 min", "Last 15 min", "Last 1 hour", "Last 6 hours"],
      "default": "Last 15 min"
    },
    {
      "id": "event_type",
      "type": "select",
      "dataSource": "Real-time Events",
      "field": "event_type"
    }
  ],
  "layout": {
    "type": "grid",
    "columns": 2,
    "widgets": [
      {"chart": "live_message_rate", "position": {"row": 0, "col": 0, "width": 2}},
      {"chart": "processing_latency", "position": {"row": 1, "col": 0, "width": 2}},
      {"chart": "error_rate", "position": {"row": 2, "col": 0}},
      {"chart": "system_health", "position": {"row": 2, "col": 1}}
    ]
  },
  "realTimeConfig": {
    "enabled": true,
    "updateInterval": 10,
    "autoRefresh": true
  }
}

{
  "displayName": "AI Automation Workflows Metrics",
  "gridLayout": {
    "columns": "2",
    "widgets": [
      {
        "title": "Enterprise AI Commands Processed",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "prometheusQuerySource": {
                  "prometheusQuery": "rate(enterprise_ai_commands_processed[5m])"
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Commands/sec"
            }
          ],
          "timeshiftDuration": "0s",
          "yAxis": {
            "scale": "LINEAR"
          }
        }
      },
      {
        "title": "Workflow Success Rate",
        "scorecard": {
          "gaugeView": {
            "upperBound": 100,
            "lowerBound": 0
          },
          "dataSets": [
            {
              "timeSeriesQuery": {
                "prometheusQuerySource": {
                  "prometheusQuery": "sum(rate(workflow_success_total[5m])) / sum(rate(workflow_total[5m])) * 100"
                }
              }
            }
          ]
        }
      },
      {
        "title": "LLM Response Time",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "prometheusQuerySource": {
                  "prometheusQuery": "histogram_quantile(0.95, rate(llm_response_time_seconds_bucket[5m]))"
                }
              },
              "plotType": "LINE",
              "legendTemplate": "95th percentile"
            }
          ],
          "yAxis": {
            "scale": "LINEAR",
            "label": "Response Time (seconds)"
          }
        }
      },
      {
        "title": "Gesture Recognition Accuracy",
        "scorecard": {
          "gaugeView": {
            "upperBound": 100,
            "lowerBound": 0
          },
          "dataSets": [
            {
              "timeSeriesQuery": {
                "prometheusQuerySource": {
                  "prometheusQuery": "gesture_recognition_accuracy * 100"
                }
              }
            }
          ]
        }
      }
    ]
  }
}

{
  "name": "AI Automation Analytics Dashboard",
  "description": "Comprehensive analytics for AI automation workflows including Enterprise AI commands, LLM performance, and workflow metrics",
  "dataSources": [
    {
      "name": "Enterprise AI Command Metrics",
      "type": "bigquery",
      "project_id": "${GCP_PROJECT_ID}",
      "dataset": "automation_metrics",
      "table": "enterprise_ai_commands",
      "refresh": "1m"
    },
    {
      "name": "Workflow Performance",
      "type": "bigquery", 
      "project_id": "${GCP_PROJECT_ID}",
      "dataset": "automation_metrics",
      "table": "workflow_performance",
      "refresh": "5m"
    },
    {
      "name": "LLM Response Data",
      "type": "bigquery",
      "project_id": "${GCP_PROJECT_ID}",
      "dataset": "automation_metrics", 
      "table": "llm_responses",
      "refresh": "1m"
    }
  ],
  "charts": [
    {
      "id": "command_volume",
      "title": "Command Processing Volume",
      "type": "time_series",
      "dataSource": "Enterprise AI Command Metrics",
      "dimensions": ["timestamp"],
      "metrics": ["command_count"],
      "aggregation": "sum"
    },
    {
      "id": "success_rate",
      "title": "Workflow Success Rate",
      "type": "gauge",
      "dataSource": "Workflow Performance",
      "metrics": ["success_rate"],
      "ranges": [{"min": 0, "max": 100}]
    },
    {
      "id": "response_time",
      "title": "LLM Response Time",
      "type": "bar_chart",
      "dataSource": "LLM Response Data",
      "dimensions": ["model_type"],
      "metrics": ["avg_response_time"]
    },
    {
      "id": "gesture_accuracy",
      "title": "Gesture Recognition Accuracy",
      "type": "scorecard",
      "dataSource": "Enterprise AI Command Metrics",
      "metrics": ["gesture_accuracy"],
      "format": "percentage"
    }
  ],
  "filters": [
    {
      "id": "time_range",
      "type": "date_range",
      "default": "last_24_hours"
    },
    {
      "id": "command_type",
      "type": "select",
      "dataSource": "Enterprise AI Command Metrics",
      "field": "command_type"
    }
  ],
  "layout": {
    "type": "grid",
    "columns": 2,
    "widgets": [
      {"chart": "command_volume", "position": {"row": 0, "col": 0, "width": 2}},
      {"chart": "success_rate", "position": {"row": 1, "col": 0}},
      {"chart": "response_time", "position": {"row": 1, "col": 1}},
      {"chart": "gesture_accuracy", "position": {"row": 2, "col": 0, "width": 2}}
    ]
  }
}
